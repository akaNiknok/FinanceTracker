      ],
      "id": "a59aaa8a-3b82-4dbe-97e2-19bc13e60072",
      "name": "Parse Sheets Response"
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  const { sheet, rows } = item.json;\n\n  for (const [name, fields] of Object.entries(rows)) {\n    items.push({\n      json: {\n        _sheet: sheet,\n        Name: name,\n        ...fields,\n      },\n    });\n  }\n}\n\nreturn items;"
      },
