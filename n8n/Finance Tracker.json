    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nreturn [\n  {\n    json: { sheet: \"Categories\", rows: data.Categories },\n  },\n  {\n    json: { sheet: \"Accounts\", rows: data.Accounts },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
